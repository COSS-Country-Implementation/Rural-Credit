{
  "name": "vc-sdk",
  "version": "1.0.0",
  "description": "Complete Verifiable Credentials SDK for React Native - Digital Identity Wallet functionality with secure storage, and credential management",
  "main": "./lib/module/index.js",
  "react-native": "./lib/module/index.js",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "example": "yarn workspace vc-sdk-example",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "clean": "del-cli lib",
    "prepare": "bob build --target module",
    "build:docs": "typedoc src --out docs/api",
    "release": "release-it --only-version"
  },
  "keywords": [
    "verifiable-credentials",
    "digital-identity",
    "react-native",
    "encryption",
    "wallet",
    "credentials",
    "identity",
    "security",
    "blockchain",
    "DID",
    "VP",
    "VC"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pankaj7121993/vc-sdk.git"
  },
  "author": "VC SDK Team <pankajchaudhary7121994@gmail.com> (https://github.com/pankaj7121993)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/pankaj7121993/vc-sdk/issues"
  },
  "homepage": "https://github.com/pankaj7121993/vc-sdk#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-private-methods": "^7.18.6",
    "@babel/plugin-transform-class-properties": "^7.27.1",
    "@babel/plugin-transform-private-methods": "^7.27.1",
    "@babel/preset-typescript": "^7.27.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/compat": "^1.3.2",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.35.0",
    "@evilmartians/lefthook": "^1.12.3",
    "@react-native/babel-preset": "0.81.1",
    "@react-native/eslint-config": "^0.81.1",
    "@release-it/conventional-changelog": "^10.0.1",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.1.12",
    "commitlint": "^19.8.1",
    "del-cli": "^6.0.0",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^29.7.0",
    "prettier": "^3.6.2",
    "react-native-builder-bob": "^0.40.13",
    "release-it": "^19.0.4",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@digitalcredentials/vc": "^1.1.2",
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.8.0",
    "@noble/secp256k1": "^2.3.0",
    "@xstate/react": "^3.0.1",
    "base64url-universal": "^1.1.0",
    "buffer": "^6.0.3",
    "color-diff": "^1.4.0",
    "crypto-js": "^4.2.0",
    "date-fns": "^2.26.0",
    "elliptic": "^6.6.1",
    "jose": "^6.1.0",
    "jsonpath-plus": "^10.0.0",
    "jwt-decode": "^3.1.2",
    "node-forge": "^1.3.1",
    "react-native-get-random-values": "^1.11.0",
    "short-unique-id": "^4.4.4",
    "uuid": "^11.0.3",
    "xstate": "^4.35.0"
  },
  "peerDependencies": {
    "@react-native-async-storage/async-storage": ">=1.17.0",
    "@react-native-community/netinfo": ">=9.0.0",
    "expo-crypto": ">=13.0.0",
    "react": ">=18.0.0",
    "react-native": ">=0.70.0",
    "react-native-device-info": ">=8.0.0",
    "react-native-fs": ">=2.18.0",
    "react-native-keychain": ">=8.0.0",
    "react-native-mmkv": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "expo-crypto": {
      "optional": true
    }
  },
  "workspaces": [
    "example"
  ],
  "packageManager": "yarn@3.6.1",
  "jest": {
    "preset": "react-native",
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release ${version}",
      "tagName": "v${version}"
    },
    "npm": {
      "publish": true
    },
    "github": {
      "release": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": {
          "name": "angular"
        }
      }
    }
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "create-react-native-library": {
    "languages": "js",
    "type": "library",
    "version": "0.54.2"
  }
}
